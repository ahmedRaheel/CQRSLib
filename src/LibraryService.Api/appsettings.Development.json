{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=RAhmed;Initial Catalog=LibraryService;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Enrichers.Environment" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/LibraryService-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Properties": {
      "Application": "LibraryService",
      "Environment": "Development"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "LibraryService",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*"
}